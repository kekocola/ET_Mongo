<Window x:Class="ETMongoAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ET Mongo 管理工具"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" Padding="24,0">
            <DockPanel LastChildFill="True">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ET Mongo 管理工具"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Text="玩家数据管理 · Mongo 性能观察 · 连接配置"
                               Foreground="#CBD5E1"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding WorkspaceTitle}"
                               Foreground="#E2E8F0"
                               Margin="0,0,16,0"
                               VerticalAlignment="Center" />
                    <Button Content="断开连接"
                            Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsWorkspaceOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SecondaryButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="MongoDB 连接"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="管理 ET 服务器对应的 Mongo 连接配置。"
                                   Foreground="#64748B"
                                   Margin="0,6,0,14"
                                   TextWrapping="Wrap" />
                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Visibility="{Binding HasNoConnections, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="暂无连接。请先点击“新增连接”创建 MongoDB 连接配置。"
                                       Foreground="#1D4ED8"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Connections}"
                             SelectedItem="{Binding SelectedConnection}"
                             Margin="0,16,0,16"
                             BorderBrush="#E2E8F0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="2">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A" />
                                        <TextBlock Text="{Binding Endpoint}"
                                                   Foreground="#64748B"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding Database}"
                                                   Foreground="#94A3B8"
                                                   FontSize="12"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2">
                        <WrapPanel Margin="0,0,0,10">
                            <Button Content="新增连接"
                                    Command="{Binding AddConnectionCommand}"
                                    Style="{StaticResource PrimaryButton}" />
                            <Button Content="编辑"
                                    Command="{Binding EditConnectionCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="删除"
                                    Command="{Binding DeleteConnectionCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                        </WrapPanel>
                        <Button Content="连接并打开工作区"
                                Command="{Binding OpenWorkspaceCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="22">
                <Grid>
                    <Grid Visibility="{Binding IsWorkspaceClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Width="520">
                            <TextBlock Text="请选择或新增 MongoDB 连接"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"
                                       TextAlignment="Center" />
                            <TextBlock Text="连接配置完成后即可进入工作区。当前版本先完成 UI 框架与交互骨架，后续会接入真实 MongoDB 连接、玩家数据读写和性能监控。"
                                       Foreground="#64748B"
                                       Margin="0,14,0,24"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                            <Button Content="新增连接"
                                    Command="{Binding AddConnectionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding IsWorkspaceOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TabControl>
                            <TabItem Header="玩家查询">
                                <Grid Margin="18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="玩家数据查询"
                                               FontSize="22"
                                               FontWeight="SemiBold" />
                                    <Border Grid.Row="1"
                                            Margin="0,16,0,0"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="查询条件区（占位）"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="后续可按玩家 ID、账号、角色名、区服等维度查询 ET 玩家数据。"
                                                       Foreground="#64748B"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="数据导出">
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="玩家数据导出"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="导出条件、字段选择、导出格式与任务记录区域预留。"
                                                   Foreground="#64748B"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="数据导入">
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="玩家数据导入"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="导入文件选择、预校验、冲突策略与执行结果区域预留。"
                                                   Foreground="#64748B"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="批量修改">
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="玩家数据批量修改"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="批量筛选、修改表达式、风险确认与回滚记录区域预留。"
                                                   Foreground="#64748B"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Mongo 性能">
                                <Grid Margin="18">
                                    <StackPanel>
                                        <TextBlock Text="Mongo 服务器性能"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="连接状态、QPS、慢查询、集合大小、索引状态等监控区域预留。"
                                                   Foreground="#64748B"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="连接管理">
                                <Grid Margin="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="1.4*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="连接管理"
                                                   FontSize="22"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="可在这里维护 MongoDB 连接配置。当前配置仅保存在内存中。"
                                                   Foreground="#64748B"
                                                   Margin="0,12,0,18"
                                                   TextWrapping="Wrap" />
                                        <Button Content="新增连接"
                                                Command="{Binding AddConnectionCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                HorizontalAlignment="Left" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="当前连接"
                                                       FontWeight="SemiBold"
                                                       FontSize="16" />
                                            <TextBlock Text="{Binding SelectedConnection.Name, TargetNullValue=未选择}"
                                                       Margin="0,10,0,0" />
                                            <TextBlock Text="{Binding SelectedConnection.Endpoint, TargetNullValue=暂无地址}"
                                                       Foreground="#64748B"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding SelectedConnection.Database, TargetNullValue=暂无数据库}"
                                                       Foreground="#64748B"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.ColumnSpan="3"
                    Background="#80000000"
                    Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="520"
                        Background="White"
                        CornerRadius="12"
                        Padding="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding EditorTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock Text="当前仅维护连接配置 UI，保存后会加入左侧连接列表。"
                                   Foreground="#64748B"
                                   Margin="0,8,0,20"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="连接名称" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding EditingConnection.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"
                                 MinHeight="32" />

                        <TextBlock Text="Host" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding EditingConnection.Host, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"
                                 MinHeight="32" />

                        <TextBlock Text="Port" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding EditingConnection.Port, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"
                                 MinHeight="32" />

                        <TextBlock Text="Database" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding EditingConnection.Database, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,14"
                                 MinHeight="32" />

                        <TextBlock Text="用户名（可选）" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding EditingConnection.UserName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,18"
                                 MinHeight="32" />

                        <TextBlock Text="{Binding EditorError}"
                                   Foreground="#DC2626"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14" />

                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="取消"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Content="保存"
                                    Command="{Binding SaveConnectionCommand}"
                                    Style="{StaticResource PrimaryButton}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
